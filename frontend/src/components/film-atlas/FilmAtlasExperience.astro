---
interface Props {
  dataBase: string;
}

const { dataBase } = Astro.props;
---

<div class="film-atlas-page relative left-1/2 w-screen -translate-x-1/2 overflow-hidden bg-[#050505] text-[#f7ead2]" data-film-atlas-root data-data-base={dataBase}>
  <section class="atlas-shell relative overflow-hidden border-b border-[#f2c46d]/15">
    <div class="atlas-page-field absolute inset-0"></div>
    <div class="atlas-app-frame relative mx-auto flex max-w-[1540px] flex-col">
      <header class="atlas-masthead">
        <div class="atlas-title-block">
          <p class="atlas-eyebrow">Static cinema topology</p>
          <h1>The Film Atlas</h1>
          <p class="atlas-dek">
            A navigable map of cinema's hidden genres, built from semantic movie profiles and nearest-neighbor evidence.
          </p>
        </div>
        <dl class="atlas-stat-grid">
          <div>
            <dt>Films</dt>
            <dd data-atlas-movie-count>10,000</dd>
          </div>
          <div>
            <dt>Regions</dt>
            <dd data-atlas-cluster-count>946</dd>
          </div>
          <div>
            <dt>Export</dt>
            <dd data-atlas-generated-at>Static</dd>
          </div>
        </dl>
      </header>

      <div class="atlas-workspace">
        <section class="atlas-map-panel" aria-label="Interactive movie map">
          <div class="atlas-toolbar">
            <form class="atlas-search-form" data-atlas-search-form>
              <label class="sr-only" for="film-atlas-search">Search by movie title</label>
              <input
                id="film-atlas-search"
                class="atlas-search-input"
                data-atlas-search
                autocomplete="off"
                placeholder="Search by movie title"
                type="search"
              />
              <div class="atlas-search-results" data-atlas-search-results hidden></div>
            </form>

            <div class="atlas-control-rack">
              <span class="atlas-tier-pill" data-atlas-label-tier>Macro clusters</span>
              <div class="atlas-zoom-controls">
                <button class="atlas-icon-button" type="button" data-atlas-zoom-out aria-label="Zoom out">-</button>
                <button class="atlas-icon-button" type="button" data-atlas-zoom-in aria-label="Zoom in">+</button>
                <button class="atlas-reset-button" type="button" data-atlas-reset>Reset</button>
              </div>
              <button class="atlas-selected-map-chip" type="button" data-atlas-selected-chip hidden>
                <span data-atlas-selected-chip-title></span>
                <span class="atlas-selected-map-chip-action">Recenter</span>
              </button>
            </div>
          </div>

          <div class="atlas-stage" data-atlas-stage>
            <canvas class="absolute inset-0 h-full w-full touch-none cursor-grab" data-atlas-canvas aria-label="Interactive semantic territory map of 10,000 films"></canvas>
            <div class="atlas-tooltip" data-atlas-tooltip hidden></div>
            <div class="atlas-loading" data-atlas-status hidden>
              Loading constellation
            </div>
          </div>
        </section>

        <aside class="atlas-detail-panel">
          <div class="atlas-detail-scroll">
            <p class="atlas-panel-eyebrow">Selected film</p>
            <h2 data-atlas-selected-title>
              The Film Atlas
            </h2>
            <p class="atlas-selected-meta" data-atlas-selected-meta>
              10,000 films arranged by semantic distance
            </p>
            <div class="atlas-genre-row" data-atlas-selected-genres></div>
            <p class="atlas-selected-overview" data-atlas-selected-overview>
              A static cinema topology built from public movie metadata, layered clustering, and semantic territory layout.
            </p>

            <div class="atlas-selected-labels" data-atlas-selected-labels></div>

            <div class="atlas-neighbor-section" data-atlas-neighbor-section hidden>
              <h3>Nearest neighbors</h3>
              <div class="atlas-neighbor-list" data-atlas-neighbors></div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="atlas-method-section">
    <div class="atlas-method-grid">
      <div class="atlas-method-heading">
        <p class="atlas-eyebrow">Methodology</p>
        <h2>A map of movie meaning, not release metadata.</h2>
      </div>
      <div class="atlas-method-copy">
        <p>
          Each dot is one movie from the static Film Atlas export. The page reads public JSON only: movie display metadata, UMAP x/y points, layered cluster labels, and nearest-neighbor lists.
        </p>
        <p>
          The map uses an offline semantic projection as evidence, then nests films into macro territories, neighborhoods, and microclusters so the interface behaves more like a readable atlas than a raw scatterplot.
        </p>
        <p>
          The public export manifest reports no API keys, embeddings, or raw reviews. The frontend does not call external APIs and does not ship the pipeline's intermediate artifacts.
        </p>
      </div>
    </div>
  </section>

  <section class="atlas-credit-section">
    <div>
      <p>
        Movie metadata is sourced from TMDB. This product uses the TMDB API but is not endorsed or certified by TMDB.
      </p>
    </div>
  </section>
</div>

<script>
  import { initFilmAtlas } from "../../lib/film-atlas/map";

  for (const root of document.querySelectorAll<HTMLElement>("[data-film-atlas-root]")) {
    initFilmAtlas(root);
  }
</script>

<style>
  :global(body:has(.film-atlas-page)) {
    --bg: 30 12% 3%;
    --fg: 42 36% 93%;
    --muted: 41 17% 66%;
    --surface: 30 10% 6%;
    --border: 36 28% 18%;
    --accent: 38 82% 69%;
    background: #050505;
  }

  :global(html:has(.film-atlas-page)) {
    background: #050505;
  }

  .film-atlas-page {
    font-feature-settings: "kern";
  }

  .atlas-shell {
    min-height: calc(100vh - 3.5rem);
  }

  .atlas-page-field {
    background:
      linear-gradient(180deg, rgba(5, 5, 5, 0.10), rgba(5, 5, 5, 0.88)),
      linear-gradient(110deg, rgba(104, 216, 197, 0.10), transparent 36%),
      linear-gradient(250deg, rgba(242, 196, 109, 0.11), transparent 42%),
      repeating-linear-gradient(90deg, rgba(242, 196, 109, 0.028) 0 1px, transparent 1px 112px),
      repeating-linear-gradient(0deg, rgba(104, 216, 197, 0.020) 0 1px, transparent 1px 112px),
      #050505;
  }

  .atlas-page-field::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(125deg, rgba(242, 196, 109, 0.10), transparent 32%),
      linear-gradient(238deg, rgba(104, 216, 197, 0.09), transparent 38%),
      linear-gradient(180deg, transparent, rgba(5, 5, 5, 0.64));
    content: "";
    opacity: 0.78;
  }

  .atlas-app-frame {
    min-height: calc(100vh - 3.5rem);
    padding: clamp(1.1rem, 2vw, 2rem);
  }

  .atlas-masthead {
    align-items: end;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.52fr);
    margin-bottom: 1rem;
  }

  .atlas-title-block {
    max-width: 58rem;
  }

  .atlas-eyebrow,
  .atlas-panel-eyebrow,
  .atlas-stat-grid dt,
  .atlas-neighbor-section h3 {
    color: #68d8c5;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .atlas-title-block h1 {
    color: #fff8ea;
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 4.65rem;
    font-weight: 600;
    line-height: 0.92;
    margin: 0.42rem 0 0;
  }

  .atlas-dek {
    color: rgba(217, 199, 163, 0.86);
    font-size: 1.08rem;
    line-height: 1.55;
    margin: 0.78rem 0 0;
    max-width: 46rem;
  }

  .atlas-stat-grid {
    display: grid;
    gap: 0.55rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0;
  }

  .atlas-stat-grid div {
    background: rgba(5, 5, 5, 0.42);
    border: 1px solid rgba(242, 196, 109, 0.16);
    border-radius: 8px;
    padding: 0.76rem 0.85rem;
  }

  .atlas-stat-grid dd {
    color: #fff8ea;
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 1.28rem;
    line-height: 1.1;
    margin: 0.18rem 0 0;
    white-space: nowrap;
  }

  .atlas-workspace {
    display: grid;
    flex: 1;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) minmax(330px, 0.34fr);
    min-height: 0;
  }

  .atlas-map-panel,
  .atlas-detail-panel {
    background: rgba(7, 7, 6, 0.88);
    border: 1px solid rgba(242, 196, 109, 0.18);
    border-radius: 8px;
    box-shadow: 0 24px 90px rgba(0, 0, 0, 0.42);
    min-width: 0;
    overflow: hidden;
  }

  .atlas-map-panel {
    display: grid;
    grid-template-rows: auto minmax(28rem, 1fr);
  }

  .atlas-toolbar {
    align-items: center;
    background: rgba(8, 8, 7, 0.84);
    border-bottom: 1px solid rgba(242, 196, 109, 0.12);
    display: grid;
    gap: 0.72rem;
    grid-template-columns: minmax(20rem, 1fr) auto;
    padding: 0.72rem;
  }

  .atlas-search-form {
    min-width: 0;
    position: relative;
  }

  .atlas-search-input {
    background: rgba(13, 11, 9, 0.92);
    border: 1px solid rgba(242, 196, 109, 0.22);
    border-radius: 6px;
    color: #fff8ea;
    font-family: Inter, ui-sans-serif, system-ui;
    font-size: 0.9rem;
    height: 2.7rem;
    outline: none;
    padding: 0 0.95rem;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
    width: 100%;
  }

  .atlas-search-input::placeholder {
    color: rgba(217, 199, 163, 0.48);
  }

  .atlas-search-input:focus {
    background: rgba(16, 13, 11, 0.98);
    border-color: rgba(242, 196, 109, 0.58);
    box-shadow: 0 0 0 3px rgba(242, 196, 109, 0.10);
  }

  .atlas-control-rack {
    align-items: center;
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    min-width: 0;
  }

  .atlas-tier-pill {
    background: rgba(7, 18, 17, 0.88);
    border: 1px solid rgba(104, 216, 197, 0.24);
    border-radius: 6px;
    color: #8ee6d9;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.66rem;
    line-height: 1;
    padding: 0.76rem 0.78rem;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .atlas-zoom-controls {
    display: inline-flex;
    gap: 0.32rem;
  }

  .atlas-selected-map-chip {
    align-items: center;
    background: rgba(17, 14, 10, 0.94);
    border: 1px solid rgba(242, 196, 109, 0.42);
    border-radius: 6px;
    color: #fff8ea;
    display: inline-flex;
    font-family: Inter, ui-sans-serif, system-ui;
    font-size: 0.76rem;
    gap: 0.5rem;
    line-height: 1;
    max-width: min(18rem, 34vw);
    min-height: 2.25rem;
    min-width: 0;
    padding: 0.62rem 0.72rem;
    white-space: nowrap;
  }

  .atlas-selected-map-chip:hover,
  .atlas-selected-map-chip:focus-visible {
    background: rgba(31, 23, 13, 0.98);
    border-color: rgba(242, 196, 109, 0.74);
    outline: none;
  }

  .atlas-selected-map-chip[hidden] {
    display: none;
  }

  .atlas-selected-map-chip span:first-child {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .atlas-selected-map-chip-action {
    color: #f2c46d;
    flex: 0 0 auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.64rem;
    text-transform: uppercase;
  }

  .atlas-stage {
    background: #030303;
    min-height: clamp(31rem, calc(100vh - 17.5rem), 48rem);
    overflow: hidden;
    position: relative;
    touch-action: none;
    user-select: none;
  }

  .atlas-stage::after {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(242, 196, 109, 0.08);
    box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.64);
    content: "";
    pointer-events: none;
  }

  :global([data-atlas-status][hidden]) {
    display: none !important;
  }

  .atlas-loading {
    align-items: center;
    background: rgba(5, 5, 5, 0.78);
    color: #f2c46d;
    display: flex;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    inset: 0;
    justify-content: center;
    pointer-events: none;
    position: absolute;
    text-transform: uppercase;
  }

  .atlas-detail-panel {
    align-self: stretch;
  }

  .atlas-detail-scroll {
    max-height: calc(100vh - 8.2rem);
    overflow: auto;
    padding: 1.25rem;
  }

  .atlas-detail-panel h2 {
    color: #fff8ea;
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 2.55rem;
    font-weight: 600;
    line-height: 1.02;
    margin: 0.62rem 0 0;
    overflow-wrap: anywhere;
  }

  .atlas-selected-meta {
    color: rgba(217, 199, 163, 0.72);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
    line-height: 1.45;
    margin: 0.56rem 0 0;
    text-transform: uppercase;
  }

  .atlas-genre-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin-top: 1.15rem;
  }

  .atlas-selected-overview {
    color: #d9c7a3;
    font-size: 0.94rem;
    line-height: 1.75;
    margin: 1.2rem 0 0;
  }

  .atlas-selected-labels {
    display: grid;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .atlas-neighbor-section {
    border-top: 1px solid rgba(242, 196, 109, 0.14);
    margin-top: 1.7rem;
    padding-top: 1.25rem;
  }

  .atlas-neighbor-section h3 {
    color: #f2c46d;
    margin: 0;
  }

  .atlas-neighbor-list {
    display: grid;
    gap: 0.5rem;
    margin-top: 0.72rem;
  }

  .atlas-icon-button,
  .atlas-reset-button {
    align-items: center;
    background: rgba(13, 11, 9, 0.9);
    border: 1px solid rgba(242, 196, 109, 0.2);
    border-radius: 6px;
    color: #fff8ea;
    display: inline-flex;
    font-family: Inter, ui-sans-serif, system-ui;
    height: 2.25rem;
    justify-content: center;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease;
  }

  .atlas-icon-button {
    font-size: 1.05rem;
    width: 2.25rem;
  }

  .atlas-reset-button {
    font-size: 0.78rem;
    padding: 0 0.72rem;
  }

  .atlas-icon-button:hover,
  .atlas-reset-button:hover {
    background: rgba(242, 196, 109, 0.1);
    border-color: rgba(242, 196, 109, 0.48);
    color: #f2c46d;
  }

  :global(.atlas-tooltip) {
    background: rgba(7, 7, 7, 0.92);
    border: 1px solid rgba(242, 196, 109, 0.28);
    border-radius: 6px;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.44);
    color: #fff8ea;
    left: 0;
    max-width: min(280px, calc(100% - 20px));
    padding: 0.7rem 0.82rem;
    pointer-events: none;
    position: absolute;
    top: 0;
    z-index: 10;
  }

  :global(.atlas-tooltip-title) {
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 1rem;
    line-height: 1.15;
  }

  :global(.atlas-tooltip-meta) {
    color: rgba(217, 199, 163, 0.78);
    font-family: Inter, ui-sans-serif, system-ui;
    font-size: 0.73rem;
    line-height: 1.35;
    margin-top: 0.28rem;
  }

  .atlas-search-results {
    background: rgba(7, 7, 7, 0.98);
    border: 1px solid rgba(242, 196, 109, 0.22);
    border-radius: 6px;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.42);
    left: 0;
    max-height: 22rem;
    overflow: auto;
    padding: 0.35rem;
    position: absolute;
    right: 0;
    top: calc(100% + 0.45rem);
    z-index: 20;
  }

  :global(.atlas-search-result),
  :global(.atlas-neighbor-button) {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 5px;
    color: #fff8ea;
    display: grid;
    gap: 0.16rem;
    padding: 0.65rem 0.7rem;
    text-align: left;
    transition: background 160ms ease, border-color 160ms ease;
    width: 100%;
  }

  :global(.atlas-search-result:hover),
  :global(.atlas-search-result[aria-selected="true"]),
  :global(.atlas-neighbor-button:hover) {
    background: rgba(242, 196, 109, 0.08);
    border-color: rgba(242, 196, 109, 0.18);
  }

  :global(.atlas-search-title),
  :global(.atlas-neighbor-title) {
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 1rem;
    line-height: 1.2;
  }

  :global(.atlas-search-meta),
  :global(.atlas-neighbor-score),
  :global(.atlas-search-empty) {
    color: rgba(217, 199, 163, 0.7);
    font-family: Inter, ui-sans-serif, system-ui;
    font-size: 0.73rem;
    line-height: 1.3;
  }

  :global(.atlas-search-empty) {
    padding: 0.75rem;
  }

  :global(.atlas-neighbor-button) {
    align-items: center;
    grid-template-columns: 1fr auto;
  }

  :global(.atlas-label-pill) {
    align-items: flex-start;
    background: rgba(255, 248, 234, 0.035);
    border: 1px solid rgba(242, 196, 109, 0.14);
    border-radius: 6px;
    color: #f7ead2;
    display: grid;
    gap: 0.2rem;
    padding: 0.62rem 0.72rem;
  }

  :global(.atlas-label-disclosure) {
    background: rgba(255, 248, 234, 0.035);
    border: 1px solid rgba(242, 196, 109, 0.14);
    border-radius: 6px;
    color: #f7ead2;
    overflow: hidden;
  }

  :global(.atlas-label-disclosure[open]) {
    border-color: rgba(104, 216, 197, 0.28);
    background: rgba(104, 216, 197, 0.045);
  }

  :global(.atlas-label-summary) {
    align-items: center;
    cursor: pointer;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    list-style: none;
    padding: 0.62rem 0.72rem;
  }

  :global(.atlas-label-summary::-webkit-details-marker) {
    display: none;
  }

  :global(.atlas-label-summary-text) {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  :global(.atlas-label-value) {
    color: #f7ead2;
    line-height: 1.25;
  }

  :global(.atlas-label-count) {
    color: rgba(217, 199, 163, 0.66);
    font-family: Inter, ui-sans-serif, system-ui;
    font-size: 0.72rem;
    line-height: 1.2;
  }

  :global(.atlas-label-chevron) {
    border-bottom: 2px solid rgba(104, 216, 197, 0.82);
    border-right: 2px solid rgba(104, 216, 197, 0.82);
    flex: 0 0 auto;
    height: 0.46rem;
    transform: rotate(45deg);
    transition: transform 160ms ease, border-color 160ms ease;
    width: 0.46rem;
  }

  :global(.atlas-label-disclosure[open] .atlas-label-chevron) {
    border-color: rgba(242, 196, 109, 0.88);
    transform: rotate(225deg);
  }

  :global(.atlas-label-key) {
    color: #68d8c5;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.64rem;
    text-transform: uppercase;
  }

  :global(.atlas-cluster-members) {
    border-top: 1px solid rgba(242, 196, 109, 0.12);
    display: grid;
    max-height: 18rem;
    overflow: auto;
    padding: 0.35rem;
  }

  :global(.atlas-cluster-member) {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 5px;
    color: #fff8ea;
    display: grid;
    gap: 0.14rem;
    padding: 0.5rem 0.55rem;
    text-align: left;
    transition: background 160ms ease, border-color 160ms ease;
    width: 100%;
  }

  :global(.atlas-cluster-member:hover),
  :global(.atlas-cluster-member[aria-current="true"]) {
    background: rgba(242, 196, 109, 0.08);
    border-color: rgba(242, 196, 109, 0.18);
  }

  :global(.atlas-cluster-member-title) {
    font-size: 0.86rem;
    line-height: 1.2;
  }

  :global(.atlas-cluster-member-meta) {
    color: rgba(217, 199, 163, 0.64);
    font-size: 0.68rem;
    line-height: 1.25;
  }

  :global(.atlas-genre-pill) {
    border: 1px solid rgba(104, 216, 197, 0.22);
    border-radius: 4px;
    color: #9ee7dc;
    font-size: 0.72rem;
    padding: 0.16rem 0.42rem;
  }

  .atlas-method-section {
    background: linear-gradient(180deg, #080706, #050505);
    border-bottom: 1px solid rgba(242, 196, 109, 0.12);
    padding: clamp(3rem, 6vw, 5.5rem) clamp(1rem, 3vw, 2rem);
  }

  .atlas-method-grid {
    display: grid;
    gap: clamp(2rem, 4vw, 4rem);
    grid-template-columns: minmax(18rem, 0.78fr) minmax(0, 1fr);
    margin: 0 auto;
    max-width: 82rem;
  }

  .atlas-method-heading h2 {
    color: #fff8ea;
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 3.4rem;
    line-height: 1;
    margin: 0.7rem 0 0;
  }

  .atlas-method-copy {
    color: rgba(217, 199, 163, 0.86);
    display: grid;
    font-size: 1rem;
    gap: 1.1rem;
    line-height: 1.85;
  }

  .atlas-method-copy p {
    margin: 0;
  }

  .atlas-credit-section {
    background: #050505;
    color: rgba(217, 199, 163, 0.78);
