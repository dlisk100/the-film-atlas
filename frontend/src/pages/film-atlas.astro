---
import FilmAtlasExperience from "../components/film-atlas/FilmAtlasExperience.astro";
import AtlasLabLayout from "../layouts/AtlasLabLayout.astro";

const dataBase = "/film-atlas/data";
---

<AtlasLabLayout
  title="The Film Atlas"
  description="An interactive map of 10,000 films arranged by experiential similarity: story, mood, texture, theme, and audience perception."
>
  <FilmAtlasExperience dataBase={dataBase} />
</AtlasLabLayout>
