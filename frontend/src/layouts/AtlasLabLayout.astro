---
import "../styles/fonts.css";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Film Atlas",
  description = "An interactive map of 10,000 films arranged by experiential similarity: story, mood, texture, theme, and audience perception.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
